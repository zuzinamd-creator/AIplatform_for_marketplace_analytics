# =============================================================================
# MAIN — production-like persistent environment (Supabase Postgres + Supabase Storage)
# =============================================================================
ENVIRONMENT_MODE=MAIN

# Supabase Postgres (asyncpg). Dashboard → Settings → Database → Direct connection.
# MAIN requires host db.<project-ref>.supabase.co:5432 and ?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?ssl=require
# DATABASE_SSL_EXTRA_CA_FILE=   # optional: corporate proxy root CA (.pem)
# DATABASE_PASSWORD=            # optional: password outside URL if it contains @ : / # etc.

# Storage: reports in Supabase Storage bucket (no local fallback in MAIN)
STORAGE_BACKEND=supabase
ALLOW_LOCAL_STORAGE_FALLBACK=false
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
SUPABASE_STORAGE_BUCKET=reports

# Auth (generate a long random secret for production)
SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Alembic (migrations run with ALEMBIC_BYPASS_RLS=true via SystemSession)
ALEMBIC_BYPASS_RLS=true
MIGRATION_LOCK_KEY=83472931

# AI (set provider + key for your deployment)
AI_ENABLED=true
AI_PROVIDER=mock
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=
AI_OPENAI_MODEL=gpt-4o-mini
AI_PROMPT_RUNTIME_VERSION=v3

LOG_LEVEL=INFO
DEBUG=false
MAINTENANCE_MODE=false

# =============================================================================
# LOCAL_DEV — optional local Postgres (ephemeral unless you use persistent volume)
# =============================================================================
# ENVIRONMENT_MODE=LOCAL_DEV
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketplace
# ALLOW_LOCAL_STORAGE_FALLBACK=true
# STORAGE_BACKEND=local

# =============================================================================
# INTEGRATION — separate test DB (docker compose -p ma_integration)
# =============================================================================
# ENVIRONMENT_MODE=INTEGRATION
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/marketplace_test
